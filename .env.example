# ─── WhatsApp (Meta Graph API) ────────────────────────────────────────────
# Get from: developers.facebook.com → your app → WhatsApp → API Setup
VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_TOKEN=your_whatsapp_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# Free options: Supabase (supabase.com) or Neon (neon.tech)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/awesist

# ─── AI (Anthropic Claude Haiku) ─────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
# Replaces OpenAI — cheaper, better Hinglish support
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── App Settings ─────────────────────────────────────────────────────────
MORNING_SUMMARY_HOUR=8       # 8 = 8:00 AM daily
REMINDER_POLL_INTERVAL=30    # seconds between reminder checks

# ─── Razorpay (Subscription Payments) ────────────────────────────────────────
# Get API keys from: dashboard.razorpay.com → Settings → API Keys
# Use TEST keys (rzp_test_...) during development, LIVE keys (rzp_live_...) in production
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Get webhook secret from: dashboard.razorpay.com → Settings → Webhooks
# Configure webhook URL as: https://your-domain.com/razorpay-webhook
# Enable event: payment_link.paid
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ─── Subscription Config ──────────────────────────────────────────────────────
SUBSCRIPTION_PRICE_INR=99    # monthly price in rupees
TRIAL_DAYS=30                # free trial length in days
